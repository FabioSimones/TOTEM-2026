# ===========================================================
# Exemplo de variáveis de ambiente para rodar o backend LOCALMENTE.
#
# Copie para ".env" (mesma pasta) e ajuste se precisar — "backend/.env" já é
# ignorado pelo .gitignore da raiz do repositório, nunca commite o real.
# Os valores abaixo são fictícios, servem só para desenvolvimento local e não
# devem ser reaproveitados em nenhum outro ambiente.
#
# Estas variáveis não são lidas automaticamente pelo Maven/Spring Boot a
# partir deste arquivo — exporte-as no shell (ver README.md, seção "Variáveis
# de ambiente obrigatórias") ou configure-as no Run/Debug Configuration da
# IDE antes de rodar "mvn spring-boot:run".
# ===========================================================

# Obrigatório (TASK-097) — sem isso o startup falha (JwtSecretValidator).
# Mínimo 32 caracteres; gere o seu, não reaproveite este valor em produção.
JWT_SECRET=chave-local-de-desenvolvimento-com-mais-de-32-caracteres

# Obrigatório (TASK-098) — sem isso o startup falha (CorsOriginsValidator).
# Lista separada por vírgula, cada origem com protocolo explícito. Nunca "*".
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Opcionais — já têm o mesmo valor como default em application.yml; só
# precisam ser definidas se o seu PostgreSQL local usar valores diferentes.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=totem_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Opcionais — só necessárias para criar o primeiro SUPER_ADMIN local
# (TASK-096). Deixe SUPER_ADMIN_BOOTSTRAP_ENABLED=false (ou omita as três)
# depois do primeiro acesso. Nunca reaproveite esta senha em produção.
SUPER_ADMIN_BOOTSTRAP_ENABLED=true
SUPER_ADMIN_EMAIL=admin.local@totem.local
SUPER_ADMIN_PASSWORD=AdminLocal@2026!
